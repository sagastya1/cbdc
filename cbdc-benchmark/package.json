{
  "name": "cbdc-blockchain-benchmark",
  "version": "1.0.0",
  "description": "CBDC Benchmark: Hyperledger Besu PoA vs QBFT using Caliper",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@hyperledger/caliper-cli": "0.6.0",
    "@hyperledger/caliper-core": "0.6.0",
    "@hyperledger/caliper-ethereum": "0.6.0",
    "solc": "0.8.19",
    "web3": "1.10.4"
  },
  "scripts": {
    "install:caliper": "npm install && npx caliper bind --caliper-bind-sut ethereum:latest",
    "preprocess":      "python3 scripts/preprocess_data.py /data/realtime_txn_dataset.csv results/workload_addresses.json",
    "benchmark":       "bash run.sh",
    "clean":           "bash scripts/clean.sh"
  },
  "caliper": {
    "blockchain": "ethereum"
  }
}
